# Roundtable AI builder — host-provided and OpenAI-compatible.
#
# The build runs on the HOST's server, so only the host configures this.
# Players just join from their phones; they never need a key.
#
# Pick ONE of the two modes below, or leave everything unset to use the
# built-in offline builder (no AI required). Copy this file to `.env`.

# ── Option A: Local model (no key, $0, fully private) ──────────────────
# Run a local OpenAI-compatible server (Ollama, LM Studio, llama.cpp).
# Setting AI_API_BASE alone is enough to switch the AI builder on.
# AI_API_BASE=http://localhost:11434/v1   # Ollama's default endpoint
# AI_MODEL=llama3.1                        # a model you've pulled locally
# AI_API_KEY=                              # leave empty for local servers

# ── Option B: Cloud API key (host pays for builds) ─────────────────────
# Any OpenAI-compatible provider.
# AI_API_KEY=sk-your-key
# AI_API_BASE=https://api.openai.com/v1    # optional; defaults to OpenAI
# AI_MODEL=gpt-4o-mini                      # optional; defaults to gpt-4o-mini

# ── Server ─────────────────────────────────────────────────────────────
# PORT=5173
